{
  "name": "bradicoin-api",
  "version": "1.0.0",
  "description": "Bradicoin Mainnet RPC Server - BRD Blockchain",
  "main": "rpc-mainnet.js",
  "scripts": {
    "start": "node rpc-mainnet.js",
    "dev": "nodemon rpc-mainnet.js",
    "docker:build": "docker build -t bradicoin-rpc .",
    "docker:run": "docker run -d -p 8545:8545 --name bradicoin-mainnet bradicoin-rpc",
    "docker:stop": "docker stop bradicoin-mainnet && docker rm bradicoin-mainnet",
    "deploy": "./deploy.sh"
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.0"
  },
  "keywords": ["bradicoin", "brd", "blockchain", "rpc", "mainnet"],
  "author": "Bradicoin",
  "license": "MIT"
}
